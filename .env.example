# Importer / server-side only
TAGHAG_SUPABASE_URL=https://your-project.supabase.co
TAGHAG_SUPABASE_SECRET_KEY=sb_secret_replace-me
# Legacy fallback (still accepted but deprecated — use TAGHAG_SUPABASE_SECRET_KEY)
# TAGHAG_SUPABASE_SERVICE_ROLE_KEY=
TAGHAG_OWNER_USER_ID=00000000-0000-0000-0000-000000000001
DB_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
TAGHAG_DB_SCHEMA=public
TAGHAG_IMPORT_ACTOR_ID=00000000-0000-0000-0000-000000000001
TAGHAG_MP3_OUTPUT_ROOT=/Volumes/LOSSY/taghag
TAGHAG_POSTMAN_BIN=postman
TAGHAG_POSTMAN_COLLECTION=/path/to/provider-evidence-collection
TAGHAG_POSTMAN_ENVIRONMENT=/path/to/provider-environment.json

# Frontend-safe values only
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=replace-me
VITE_TAGHAG_APP_NAME=Taghag
VITE_TAGHAG_ENV=local

# server/ — @supabase/server SDK (Node). SERVER-SIDE ONLY; never bundled to the browser.
# Copy real values from the Supabase dashboard Connect dialog. SECRET key stays in .env (gitignored).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-me
SUPABASE_SECRET_KEY=sb_secret_replace-me
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
